# 若依后端环境变量配置
# 复制此文件为 .env 并修改相应的值

# 数据库配置
DB_URL=jdbc:mysql://your-mysql-host:3306/ry-vue?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Redis 配置
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=your-redis-password

# Druid 监控配置
DRUID_USERNAME=admin
DRUID_PASSWORD=123456

# Token 配置
TOKEN_SECRET=abcdefghijklmnopqrstuvwxyz1234567890

# 文件上传路径（Linux 路径示例）
RUOYI_PROFILE=/home/ruoyi/uploadPath

# 腾讯云COS对象存储配置
# 是否启用COS上传（true=启用COS，false=使用本地文件系统）
COS_ENABLED=false
# 腾讯云 SecretId（在腾讯云控制台获取）
COS_SECRET_ID=your-cos-secret-id
# 腾讯云 SecretKey（在腾讯云控制台获取）
COS_SECRET_KEY=your-cos-secret-key
# COS地域（如：ap-guangzhou, ap-shanghai, ap-beijing等）
COS_REGION=ap-guangzhou
# 存储桶名称（bucket名称）
COS_BUCKET_NAME=your-bucket-name
# 存储桶访问域名（可选，用于CDN加速或自定义域名）
COS_BUCKET_DOMAIN=your-bucket-domain
# 上传文件的基础路径（可选，默认为receipts）
COS_BASE_PATH=receipts
