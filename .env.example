# 若依后端环境变量配置
# 复制此文件为 .env 并修改相应的值

# 数据库配置
DB_URL=jdbc:mysql://your-mysql-host:3306/ry-vue?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Redis 配置
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=your-redis-password

# Druid 监控配置
DRUID_USERNAME=admin
DRUID_PASSWORD=123456

# Token 配置
TOKEN_SECRET=abcdefghijklmnopqrstuvwxyz1234567890

# 文件上传路径（Linux 路径示例）
RUOYI_PROFILE=/home/ruoyi/uploadPath
