<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.logistics.mapper.LogisticsVehicleMapper">

    <resultMap type="LogisticsVehicle" id="LogisticsVehicleResult">
        <result property="vehicleId"    column="vehicle_id"    />
        <result property="vehiclePlate"    column="vehicle_plate"    />
        <result property="vehicleType"    column="vehicle_type"    />
        <result property="vehicleLength"    column="vehicle_length"    />
        <result property="loadCapacity"    column="load_capacity"    />
        <result property="driverId"    column="driver_id"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectLogisticsVehicleVo">
        select vehicle_id, vehicle_plate, vehicle_type, vehicle_length, load_capacity, driver_id, status, del_flag, create_by, create_time, update_by, update_time, remark from logistics_vehicle
    </sql>

    <select id="selectLogisticsVehicleList" parameterType="LogisticsVehicle" resultMap="LogisticsVehicleResult">
        <include refid="selectLogisticsVehicleVo"/>
        <where>
            <if test="vehiclePlate != null  and vehiclePlate != ''"> and vehicle_plate like concat('%', #{vehiclePlate}, '%')</if>
            <if test="vehicleType != null  and vehicleType != ''"> and vehicle_type = #{vehicleType}</if>
            <if test="driverId != null "> and driver_id = #{driverId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by vehicle_id desc
    </select>

    <select id="selectLogisticsVehicleByVehicleId" parameterType="Long" resultMap="LogisticsVehicleResult">
        <include refid="selectLogisticsVehicleVo"/>
        where vehicle_id = #{vehicleId}
    </select>

    <insert id="insertLogisticsVehicle" parameterType="LogisticsVehicle" useGeneratedKeys="true" keyProperty="vehicleId">
        insert into logistics_vehicle
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="vehiclePlate != null and vehiclePlate != ''">vehicle_plate,</if>
            <if test="vehicleType != null">vehicle_type,</if>
            <if test="vehicleLength != null">vehicle_length,</if>
            <if test="loadCapacity != null">load_capacity,</if>
            <if test="driverId != null">driver_id,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="vehiclePlate != null and vehiclePlate != ''">#{vehiclePlate},</if>
            <if test="vehicleType != null">#{vehicleType},</if>
            <if test="vehicleLength != null">#{vehicleLength},</if>
            <if test="loadCapacity != null">#{loadCapacity},</if>
            <if test="driverId != null">#{driverId},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateLogisticsVehicle" parameterType="LogisticsVehicle">
        update logistics_vehicle
        <trim prefix="SET" suffixOverrides=",">
            <if test="vehiclePlate != null and vehiclePlate != ''">vehicle_plate = #{vehiclePlate},</if>
            <if test="vehicleType != null">vehicle_type = #{vehicleType},</if>
            <if test="vehicleLength != null">vehicle_length = #{vehicleLength},</if>
            <if test="loadCapacity != null">load_capacity = #{loadCapacity},</if>
            <if test="driverId != null">driver_id = #{driverId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where vehicle_id = #{vehicleId}
    </update>

    <delete id="deleteLogisticsVehicleByVehicleId" parameterType="Long">
        delete from logistics_vehicle where vehicle_id = #{vehicleId}
    </delete>

    <delete id="deleteLogisticsVehicleByVehicleIds" parameterType="String">
        delete from logistics_vehicle where vehicle_id in
        <foreach item="vehicleId" collection="array" open="(" separator="," close=")">
            #{vehicleId}
        </foreach>
    </delete>
</mapper>
