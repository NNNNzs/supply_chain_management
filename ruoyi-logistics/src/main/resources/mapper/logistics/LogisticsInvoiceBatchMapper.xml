<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.logistics.mapper.LogisticsInvoiceBatchMapper">

    <resultMap type="LogisticsInvoiceBatch" id="LogisticsInvoiceBatchResult">
        <result property="batchId"    column="batch_id"    />
        <result property="batchNo"    column="batch_no"    />
        <result property="customerId"    column="customer_id"    />
        <result property="invoiceDate"    column="invoice_date"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="orderCount"    column="order_count"    />
        <result property="invoiceStatus"    column="invoice_status"    />
        <result property="invoiceType"    column="invoice_type"    />
        <result property="taxRate"    column="tax_rate"    />
        <result property="taxAmount"    column="tax_amount"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectLogisticsInvoiceBatchVo">
        select batch_id, batch_no, customer_id, invoice_date, total_amount, order_count, invoice_status, invoice_type, tax_rate, tax_amount, del_flag, create_by, create_time, update_by, update_time, remark from logistics_invoice_batch
    </sql>

    <select id="selectLogisticsInvoiceBatchList" parameterType="LogisticsInvoiceBatch" resultMap="LogisticsInvoiceBatchResult">
        <include refid="selectLogisticsInvoiceBatchVo"/>
        <where>
            <if test="batchNo != null  and batchNo != ''"> and batch_no like concat('%', #{batchNo}, '%')</if>
            <if test="customerId != null "> and customer_id = #{customerId}</if>
            <if test="invoiceStatus != null  and invoiceStatus != ''"> and invoice_status = #{invoiceStatus}</if>
        </where>
        order by batch_id desc
    </select>

    <select id="selectLogisticsInvoiceBatchByBatchId" parameterType="Long" resultMap="LogisticsInvoiceBatchResult">
        <include refid="selectLogisticsInvoiceBatchVo"/>
        where batch_id = #{batchId}
    </select>

    <insert id="insertLogisticsInvoiceBatch" parameterType="LogisticsInvoiceBatch" useGeneratedKeys="true" keyProperty="batchId">
        insert into logistics_invoice_batch
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="batchNo != null and batchNo != ''">batch_no,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="invoiceDate != null">invoice_date,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="orderCount != null">order_count,</if>
            <if test="invoiceStatus != null">invoice_status,</if>
            <if test="invoiceType != null">invoice_type,</if>
            <if test="taxRate != null">tax_rate,</if>
            <if test="taxAmount != null">tax_amount,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="batchNo != null and batchNo != ''">#{batchNo},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="invoiceDate != null">#{invoiceDate},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="orderCount != null">#{orderCount},</if>
            <if test="invoiceStatus != null">#{invoiceStatus},</if>
            <if test="invoiceType != null">#{invoiceType},</if>
            <if test="taxRate != null">#{taxRate},</if>
            <if test="taxAmount != null">#{taxAmount},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateLogisticsInvoiceBatch" parameterType="LogisticsInvoiceBatch">
        update logistics_invoice_batch
        <trim prefix="SET" suffixOverrides=",">
            <if test="batchNo != null and batchNo != ''">batch_no = #{batchNo},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="invoiceDate != null">invoice_date = #{invoiceDate},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="orderCount != null">order_count = #{orderCount},</if>
            <if test="invoiceStatus != null">invoice_status = #{invoiceStatus},</if>
            <if test="invoiceType != null">invoice_type = #{invoiceType},</if>
            <if test="taxRate != null">tax_rate = #{taxRate},</if>
            <if test="taxAmount != null">tax_amount = #{taxAmount},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where batch_id = #{batchId}
    </update>

    <delete id="deleteLogisticsInvoiceBatchByBatchId" parameterType="Long">
        delete from logistics_invoice_batch where batch_id = #{batchId}
    </delete>

    <delete id="deleteLogisticsInvoiceBatchByBatchIds" parameterType="String">
        delete from logistics_invoice_batch where batch_id in
        <foreach item="batchId" collection="array" open="(" separator="," close=")">
            #{batchId}
        </foreach>
    </delete>
</mapper>
