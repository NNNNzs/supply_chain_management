<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.logistics.mapper.LogisticsBillMapper">

    <resultMap type="LogisticsBill" id="LogisticsBillResult">
        <result property="billId"    column="bill_id"    />
        <result property="billNo"    column="bill_no"    />
        <result property="billDate"    column="bill_date"    />
        <result property="customerId"    column="customer_id"    />
        <result property="customerName"    column="customer_name"    />
        <result property="loadingAddress"    column="loading_address"    />
        <result property="unloadingAddress"    column="unloading_address"    />
        <result property="totalWeight"    column="total_weight"    />
        <result property="allocatedWeight"    column="allocated_weight"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="billStatus"    column="bill_status"    />
        <result property="priority"    column="priority"    />
        <result property="requireDate"    column="require_date"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectLogisticsBillVo">
        select b.bill_id, b.bill_no, b.bill_date, b.customer_id, b.loading_address, b.unloading_address,
               b.total_weight, b.allocated_weight, b.total_amount, b.bill_status, b.priority, b.require_date,
               b.del_flag, b.create_by, b.create_time, b.update_by, b.update_time, b.remark,
               c.customer_name
        from logistics_bill b
        left join logistics_customer c on b.customer_id = c.customer_id
    </sql>

    <select id="selectLogisticsBillList" parameterType="LogisticsBill" resultMap="LogisticsBillResult">
        <include refid="selectLogisticsBillVo"/>
        <where>
            b.del_flag = '0'
            <if test="billNo != null and billNo != ''"> and b.bill_no like concat('%', #{billNo}, '%')</if>
            <if test="customerId != null"> and b.customer_id = #{customerId}</if>
            <if test="billStatus != null and billStatus != ''"> and b.bill_status = #{billStatus}</if>
            <if test="priority != null and priority != ''"> and b.priority = #{priority}</if>
            <if test="params.beginBillDate != null and params.beginBillDate != ''"> and date_format(b.bill_date,'%y%m%d') &gt;= date_format(#{params.beginBillDate},'%y%m%d')</if>
            <if test="params.endBillDate != null and params.endBillDate != ''"> and date_format(b.bill_date,'%y%m%d') &lt;= date_format(#{params.endBillDate},'%y%m%d')</if>
        </where>
        order by b.bill_id desc
    </select>

    <select id="selectLogisticsBillByBillId" parameterType="Long" resultMap="LogisticsBillResult">
        <include refid="selectLogisticsBillVo"/>
        where b.bill_id = #{billId} and b.del_flag = '0'
    </select>

    <select id="checkBillNoUnique" parameterType="String" resultMap="LogisticsBillResult">
        <include refid="selectLogisticsBillVo"/>
        where b.bill_no = #{billNo} and b.del_flag = '0' limit 1
    </select>

    <select id="selectPendingBills" parameterType="LogisticsBill" resultMap="LogisticsBillResult">
        <include refid="selectLogisticsBillVo"/>
        <where>
            b.del_flag = '0' and b.bill_status in ('pending', 'partial')
            <if test="customerId != null"> and b.customer_id = #{customerId}</if>
            <if test="priority != null and priority != ''"> and b.priority = #{priority}</if>
        </where>
        order by b.priority desc, b.bill_date asc, b.bill_id asc
    </select>

    <insert id="insertLogisticsBill" parameterType="LogisticsBill" useGeneratedKeys="true" keyProperty="billId">
        insert into logistics_bill
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no,</if>
            <if test="billDate != null">bill_date,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="loadingAddress != null">loading_address,</if>
            <if test="unloadingAddress != null">unloading_address,</if>
            <if test="totalWeight != null">total_weight,</if>
            <if test="allocatedWeight != null">allocated_weight,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="billStatus != null">bill_status,</if>
            <if test="priority != null">priority,</if>
            <if test="requireDate != null">require_date,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">#{billNo},</if>
            <if test="billDate != null">#{billDate},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="loadingAddress != null">#{loadingAddress},</if>
            <if test="unloadingAddress != null">#{unloadingAddress},</if>
            <if test="totalWeight != null">#{totalWeight},</if>
            <if test="allocatedWeight != null">#{allocatedWeight},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="billStatus != null">#{billStatus},</if>
            <if test="priority != null">#{priority},</if>
            <if test="requireDate != null">#{requireDate},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateLogisticsBill" parameterType="LogisticsBill">
        update logistics_bill
        <trim prefix="SET" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no = #{billNo},</if>
            <if test="billDate != null">bill_date = #{billDate},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="loadingAddress != null">loading_address = #{loadingAddress},</if>
            <if test="unloadingAddress != null">unloading_address = #{unloadingAddress},</if>
            <if test="totalWeight != null">total_weight = #{totalWeight},</if>
            <if test="allocatedWeight != null">allocated_weight = #{allocatedWeight},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="billStatus != null">bill_status = #{billStatus},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="requireDate != null">require_date = #{requireDate},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where bill_id = #{billId}
    </update>

    <delete id="deleteLogisticsBillByBillId" parameterType="Long">
        delete from logistics_bill where bill_id = #{billId}
    </delete>

    <delete id="deleteLogisticsBillByBillIds" parameterType="String">
        delete from logistics_bill where bill_id in
        <foreach item="billId" collection="array" open="(" separator="," close=")">
            #{billId}
        </foreach>
    </delete>
</mapper>
