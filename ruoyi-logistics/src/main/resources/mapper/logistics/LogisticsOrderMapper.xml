<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.logistics.mapper.LogisticsOrderMapper">

    <resultMap type="LogisticsOrder" id="LogisticsOrderResult">
        <id     property="orderId"            column="order_id"           />
        <result property="orderNo"            column="order_no"           />
        <result property="orderDate"          column="order_date"         />
        <result property="customerId"         column="customer_id"        />
        <result property="customerName"       column="customer_name"      />
        <result property="loadingAddress"     column="loading_address"    />
        <result property="unloadingAddress"   column="unloading_address"  />
        <result property="goodsId"            column="goods_id"           />
        <result property="goodsName"          column="goods_name"         />
        <result property="goodsModel"         column="goods_model"        />
        <result property="weight"             column="weight"             />
        <result property="actualWeight"       column="actual_weight"      />
        <result property="unitPrice"          column="unit_price"         />
        <result property="totalAmount"        column="total_amount"       />
        <result property="advancePayment"     column="advance_payment"    />
        <result property="vehicleId"          column="vehicle_id"         />
        <result property="vehiclePlate"       column="vehicle_plate"      />
        <result property="loadCapacity"       column="load_capacity"      />
        <result property="driverId"           column="driver_id"          />
        <result property="driverPhone"        column="driver_phone"       />
        <result property="loadingUnitPrice"   column="loading_unit_price" />
        <result property="freightCost"        column="freight_cost"       />
        <result property="settlementStatus"   column="settlement_status"  />
        <result property="paymentMethod"      column="payment_method"     />
        <result property="payee"              column="payee"              />
        <result property="receiptStatus"      column="receipt_status"     />
        <result property="invoiceStatus"      column="invoice_status"     />
        <result property="invoiceDate"        column="invoice_date"       />
        <result property="invoiceBatchNo"     column="invoice_batch_no"   />
        <result property="orderStatus"        column="order_status"       />
        <result property="dispatchDate"       column="dispatch_date"      />
        <result property="delFlag"            column="del_flag"           />
        <result property="createBy"           column="create_by"          />
        <result property="createTime"         column="create_time"        />
        <result property="updateBy"           column="update_by"          />
        <result property="updateTime"         column="update_time"        />
        <result property="remark"             column="remark"             />
    </resultMap>

    <sql id="selectLogisticsOrderVo">
        select o.order_id, o.order_no, o.order_date, o.customer_id, o.loading_address, o.unloading_address,
               o.goods_id, o.goods_name, o.goods_model, o.weight, o.actual_weight, o.unit_price, o.total_amount, o.advance_payment,
               o.vehicle_id, o.vehicle_plate, o.load_capacity, o.driver_id, o.driver_phone,
               o.loading_unit_price, o.freight_cost,
               o.settlement_status, o.payment_method, o.payee, o.receipt_status, o.invoice_status,
               o.invoice_date, o.invoice_batch_no, o.order_status, o.dispatch_date, o.remark,
               c.customer_name
        from logistics_order o
        left join logistics_customer c on o.customer_id = c.customer_id
    </sql>

    <select id="selectOrderList" parameterType="LogisticsOrder" resultMap="LogisticsOrderResult">
        <include refid="selectLogisticsOrderVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''">
                AND o.order_no like concat('%', #{orderNo}, '%')
            </if>
            <if test="customerId != null">
                AND o.customer_id = #{customerId}
            </if>
            <if test="params.beginOrderDate != null and params.beginOrderDate != ''">
                AND o.order_date &gt;= #{params.beginOrderDate}
            </if>
            <if test="params.endOrderDate != null and params.endOrderDate != ''">
                AND o.order_date &lt;= #{params.endOrderDate}
            </if>
            <if test="orderStatus != null and orderStatus != ''">
                AND o.order_status = #{orderStatus}
            </if>
            <if test="settlementStatus != null and settlementStatus != ''">
                AND o.settlement_status = #{settlementStatus}
            </if>
            <if test="invoiceStatus != null and invoiceStatus != ''">
                AND o.invoice_status = #{invoiceStatus}
            </if>
            AND o.del_flag = '0'
        </where>
        order by o.order_id desc
    </select>

    <select id="selectOrderById" parameterType="Long" resultMap="LogisticsOrderResult">
        <include refid="selectLogisticsOrderVo"/>
        where o.order_id = #{orderId}
    </select>

    <select id="checkOrderNoUnique" parameterType="String" resultMap="LogisticsOrderResult">
        <include refid="selectLogisticsOrderVo"/>
        where o.order_no = #{orderNo} and o.del_flag = '0' limit 1
    </select>

    <select id="checkOrderNoExistsInDb" parameterType="String" resultType="LogisticsOrder">
        select order_id, order_no from logistics_order
        where order_no = #{orderNo} limit 1
    </select>

    <select id="selectOrdersByCustomerId" parameterType="Long" resultMap="LogisticsOrderResult">
        <include refid="selectLogisticsOrderVo"/>
        where o.customer_id = #{customerId} and o.del_flag = '0'
        order by o.order_date desc
    </select>

    <insert id="insertOrder" parameterType="LogisticsOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into logistics_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="orderDate != null">order_date,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="loadingAddress != null and loadingAddress != ''">loading_address,</if>
            <if test="unloadingAddress != null and unloadingAddress != ''">unloading_address,</if>
            <if test="goodsId != null">goods_id,</if>
            <if test="goodsName != null and goodsName != ''">goods_name,</if>
            <if test="goodsModel != null and goodsModel != ''">goods_model,</if>
            <if test="weight != null">weight,</if>
            <if test="actualWeight != null">actual_weight,</if>
            <if test="unitPrice != null">unit_price,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="advancePayment != null">advance_payment,</if>
            <if test="vehicleId != null">vehicle_id,</if>
            <if test="vehiclePlate != null and vehiclePlate != ''">vehicle_plate,</if>
            <if test="loadCapacity != null">load_capacity,</if>
            <if test="driverId != null">driver_id,</if>
            <if test="driverPhone != null and driverPhone != ''">driver_phone,</if>
            <if test="loadingUnitPrice != null">loading_unit_price,</if>
            <if test="freightCost != null">freight_cost,</if>
            <if test="settlementStatus != null">settlement_status,</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method,</if>
            <if test="payee != null and payee != ''">payee,</if>
            <if test="receiptStatus != null">receipt_status,</if>
            <if test="invoiceStatus != null">invoice_status,</if>
            <if test="invoiceDate != null">invoice_date,</if>
            <if test="invoiceBatchNo != null and invoiceBatchNo != ''">invoice_batch_no,</if>
            <if test="orderStatus != null">order_status,</if>
            <if test="dispatchDate != null">dispatch_date,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="orderDate != null">#{orderDate},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="loadingAddress != null and loadingAddress != ''">#{loadingAddress},</if>
            <if test="unloadingAddress != null and unloadingAddress != ''">#{unloadingAddress},</if>
            <if test="goodsId != null">#{goodsId},</if>
            <if test="goodsName != null and goodsName != ''">#{goodsName},</if>
            <if test="goodsModel != null and goodsModel != ''">#{goodsModel},</if>
            <if test="weight != null">#{weight},</if>
            <if test="actualWeight != null">#{actualWeight},</if>
            <if test="unitPrice != null">#{unitPrice},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="advancePayment != null">#{advancePayment},</if>
            <if test="vehicleId != null">#{vehicleId},</if>
            <if test="vehiclePlate != null and vehiclePlate != ''">#{vehiclePlate},</if>
            <if test="loadCapacity != null">#{loadCapacity},</if>
            <if test="driverId != null">#{driverId},</if>
            <if test="driverPhone != null and driverPhone != ''">#{driverPhone},</if>
            <if test="loadingUnitPrice != null">#{loadingUnitPrice},</if>
            <if test="freightCost != null">#{freightCost},</if>
            <if test="settlementStatus != null">#{settlementStatus},</if>
            <if test="paymentMethod != null and paymentMethod != ''">#{paymentMethod},</if>
            <if test="payee != null and payee != ''">#{payee},</if>
            <if test="receiptStatus != null">#{receiptStatus},</if>
            <if test="invoiceStatus != null">#{invoiceStatus},</if>
            <if test="invoiceDate != null">#{invoiceDate},</if>
            <if test="invoiceBatchNo != null and invoiceBatchNo != ''">#{invoiceBatchNo},</if>
            <if test="orderStatus != null">#{orderStatus},</if>
            <if test="dispatchDate != null">#{dispatchDate},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateOrder" parameterType="LogisticsOrder">
        update logistics_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="orderDate != null">order_date = #{orderDate},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="loadingAddress != null and loadingAddress != ''">loading_address = #{loadingAddress},</if>
            <if test="unloadingAddress != null and unloadingAddress != ''">unloading_address = #{unloadingAddress},</if>
            <if test="goodsId != null">goods_id = #{goodsId},</if>
            <if test="goodsName != null">goods_name = #{goodsName},</if>
            <if test="goodsModel != null">goods_model = #{goodsModel},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="actualWeight != null">actual_weight = #{actualWeight},</if>
            <if test="unitPrice != null">unit_price = #{unitPrice},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="advancePayment != null">advance_payment = #{advancePayment},</if>
            <if test="vehicleId != null">vehicle_id = #{vehicleId},</if>
            <if test="vehiclePlate != null">vehicle_plate = #{vehiclePlate},</if>
            <if test="loadCapacity != null">load_capacity = #{loadCapacity},</if>
            <if test="driverId != null">driver_id = #{driverId},</if>
            <if test="driverPhone != null">driver_phone = #{driverPhone},</if>
            <if test="loadingUnitPrice != null">loading_unit_price = #{loadingUnitPrice},</if>
            <if test="freightCost != null">freight_cost = #{freightCost},</if>
            <if test="settlementStatus != null">settlement_status = #{settlementStatus},</if>
            <if test="paymentMethod != null">payment_method = #{paymentMethod},</if>
            <if test="payee != null">payee = #{payee},</if>
            <if test="receiptStatus != null">receipt_status = #{receiptStatus},</if>
            <if test="invoiceStatus != null">invoice_status = #{invoiceStatus},</if>
            <if test="invoiceDate != null">invoice_date = #{invoiceDate},</if>
            <if test="invoiceBatchNo != null">invoice_batch_no = #{invoiceBatchNo},</if>
            <if test="orderStatus != null">order_status = #{orderStatus},</if>
            <if test="dispatchDate != null">dispatch_date = #{dispatchDate},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteOrderById" parameterType="Long">
        update logistics_order set del_flag = '2' where order_id = #{orderId}
    </delete>

    <delete id="deleteOrderByIds" parameterType="Long">
        update logistics_order set del_flag = '2' where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <!-- 查询装货地址列表（去重并统计使用次数） -->
    <select id="selectLoadingAddressList" parameterType="String" resultType="java.util.Map">
        SELECT
            loading_address AS address,
            COUNT(*) AS count
        FROM logistics_order
        WHERE loading_address IS NOT NULL
            AND loading_address != ''
            AND del_flag = '0'
            <if test="keyword != null and keyword != ''">
                AND loading_address LIKE CONCAT('%', #{keyword}, '%')
            </if>
        GROUP BY loading_address
        ORDER BY count DESC, loading_address ASC
        LIMIT 50
    </select>

    <!-- 查询卸货地址列表（去重并统计使用次数） -->
    <select id="selectUnloadingAddressList" parameterType="String" resultType="java.util.Map">
        SELECT
            unloading_address AS address,
            COUNT(*) AS count
        FROM logistics_order
        WHERE unloading_address IS NOT NULL
            AND unloading_address != ''
            AND del_flag = '0'
            <if test="keyword != null and keyword != ''">
                AND unloading_address LIKE CONCAT('%', #{keyword}, '%')
            </if>
        GROUP BY unloading_address
        ORDER BY count DESC, unloading_address ASC
        LIMIT 50
    </select>

    <!-- 查询所有地址列表（装货和卸货合并，去重并统计使用次数） -->
    <select id="selectAllAddressList" parameterType="String" resultType="java.util.Map">
        SELECT address, SUM(count) AS total_count
        FROM (
            SELECT
                loading_address AS address,
                COUNT(*) AS count
            FROM logistics_order
            WHERE loading_address IS NOT NULL
                AND loading_address != ''
                AND del_flag = '0'
                <if test="keyword != null and keyword != ''">
                    AND loading_address LIKE CONCAT('%', #{keyword}, '%')
                </if>
            GROUP BY loading_address
            UNION ALL
            SELECT
                unloading_address AS address,
                COUNT(*) AS count
            FROM logistics_order
            WHERE unloading_address IS NOT NULL
                AND unloading_address != ''
                AND del_flag = '0'
                <if test="keyword != null and keyword != ''">
                    AND unloading_address LIKE CONCAT('%', #{keyword}, '%')
                </if>
            GROUP BY unloading_address
        ) AS combined
        GROUP BY address
        ORDER BY total_count DESC, address ASC
        LIMIT 50
    </select>

    <!-- 根据订单号前缀查询最大订单号（包括已删除的记录） -->
    <select id="selectMaxOrderNoByPrefix" parameterType="String" resultType="String">
        SELECT MAX(order_no) FROM logistics_order
        WHERE order_no LIKE CONCAT(#{orderNoPrefix}, '%')
    </select>

</mapper>
