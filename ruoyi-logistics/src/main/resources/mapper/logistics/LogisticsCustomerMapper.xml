<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.logistics.mapper.LogisticsCustomerMapper">

    <resultMap type="LogisticsCustomer" id="LogisticsCustomerResult">
        <id     property="customerId"        column="customer_id"    />
        <result property="customerCode"      column="customer_code"  />
        <result property="customerName"      column="customer_name"  />
        <result property="contactPerson"     column="contact_person" />
        <result property="contactPhone"      column="contact_phone"  />
        <result property="customerAddress"   column="customer_address"/>
        <result property="settlementType"    column="settlement_type"/>
        <result property="creditLimit"       column="credit_limit"   />
        <result property="status"            column="status"         />
        <result property="delFlag"           column="del_flag"       />
        <result property="createBy"          column="create_by"      />
        <result property="createTime"        column="create_time"    />
        <result property="updateBy"          column="update_by"      />
        <result property="updateTime"        column="update_time"    />
        <result property="remark"            column="remark"         />
    </resultMap>

    <sql id="selectLogisticsCustomerVo">
        select customer_id, customer_code, customer_name, contact_person, contact_phone, customer_address,
               settlement_type, credit_limit, status, del_flag, create_by, create_time, update_by, update_time, remark
        from logistics_customer
    </sql>

    <select id="selectCustomerList" parameterType="LogisticsCustomer" resultMap="LogisticsCustomerResult">
        <include refid="selectLogisticsCustomerVo"/>
        <where>
            <if test="customerCode != null and customerCode != ''">
                AND customer_code like concat('%', #{customerCode}, '%')
            </if>
            <if test="customerName != null and customerName != ''">
                AND customer_name like concat('%', #{customerName}, '%')
            </if>
            <if test="contactPerson != null and contactPerson != ''">
                AND contact_person like concat('%', #{contactPerson}, '%')
            </if>
            <if test="contactPhone != null and contactPhone != ''">
                AND contact_phone like concat('%', #{contactPhone}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            AND del_flag = '0'
        </where>
        order by customer_id desc
    </select>

    <select id="selectCustomerById" parameterType="Long" resultMap="LogisticsCustomerResult">
        <include refid="selectLogisticsCustomerVo"/>
        where customer_id = #{customerId}
    </select>

    <select id="checkCustomerCodeUnique" parameterType="String" resultMap="LogisticsCustomerResult">
        <include refid="selectLogisticsCustomerVo"/>
        where customer_code = #{customerCode} and del_flag = '0' limit 1
    </select>

    <insert id="insertCustomer" parameterType="LogisticsCustomer" useGeneratedKeys="true" keyProperty="customerId">
        insert into logistics_customer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="customerCode != null and customerCode != ''">customer_code,</if>
            <if test="customerName != null and customerName != ''">customer_name,</if>
            <if test="contactPerson != null and contactPerson != ''">contact_person,</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone,</if>
            <if test="customerAddress != null and customerAddress != ''">customer_address,</if>
            <if test="settlementType != null and settlementType != ''">settlement_type,</if>
            <if test="creditLimit != null">credit_limit,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="customerCode != null and customerCode != ''">#{customerCode},</if>
            <if test="customerName != null and customerName != ''">#{customerName},</if>
            <if test="contactPerson != null and contactPerson != ''">#{contactPerson},</if>
            <if test="contactPhone != null and contactPhone != ''">#{contactPhone},</if>
            <if test="customerAddress != null and customerAddress != ''">#{customerAddress},</if>
            <if test="settlementType != null and settlementType != ''">#{settlementType},</if>
            <if test="creditLimit != null">#{creditLimit},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateCustomer" parameterType="LogisticsCustomer">
        update logistics_customer
        <trim prefix="SET" suffixOverrides=",">
            <if test="customerCode != null and customerCode != ''">customer_code = #{customerCode},</if>
            <if test="customerName != null and customerName != ''">customer_name = #{customerName},</if>
            <if test="contactPerson != null">contact_person = #{contactPerson},</if>
            <if test="contactPhone != null">contact_phone = #{contactPhone},</if>
            <if test="customerAddress != null">customer_address = #{customerAddress},</if>
            <if test="settlementType != null">settlement_type = #{settlementType},</if>
            <if test="creditLimit != null">credit_limit = #{creditLimit},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where customer_id = #{customerId}
    </update>

    <delete id="deleteCustomerById" parameterType="Long">
        update logistics_customer set del_flag = '2' where customer_id = #{customerId}
    </delete>

    <delete id="deleteCustomerByIds" parameterType="Long">
        update logistics_customer set del_flag = '2' where customer_id in
        <foreach item="customerId" collection="array" open="(" separator="," close=")">
            #{customerId}
        </foreach>
    </delete>

</mapper>
