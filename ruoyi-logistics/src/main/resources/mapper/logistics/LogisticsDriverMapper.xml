<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.logistics.mapper.LogisticsDriverMapper">

    <resultMap type="LogisticsDriver" id="LogisticsDriverResult">
        <result property="driverId"    column="driver_id"    />
        <result property="driverName"    column="driver_name"    />
        <result property="driverPhone"    column="driver_phone"    />
        <result property="idCard"    column="id_card"    />
        <result property="driverLicense"    column="driver_license"    />
        <result property="driverType"    column="driver_type"    />
        <result property="fleetId"    column="fleet_id"    />
        <result property="fleetName"    column="fleet_name"    />
        <result property="vehiclePlate"    column="vehicle_plate"    />
        <result property="bankAccount"    column="bank_account"    />
        <result property="bankName"    column="bank_name"    />
        <result property="accountName"    column="account_name"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectLogisticsDriverVo">
        select d.driver_id, d.driver_name, d.driver_phone, d.id_card, d.driver_license,
               d.driver_type, d.fleet_id, f.fleet_name,
               d.vehicle_plate, d.bank_account, d.bank_name, d.account_name,
               d.status, d.del_flag, d.create_by, d.create_time, d.update_by, d.update_time, d.remark
        from logistics_driver d
        left join logistics_fleet f on d.fleet_id = f.fleet_id
    </sql>

    <select id="selectLogisticsDriverList" parameterType="LogisticsDriver" resultMap="LogisticsDriverResult">
        <include refid="selectLogisticsDriverVo"/>
        <where>
            d.del_flag = '0'
            <if test="driverName != null  and driverName != ''"> and d.driver_name like concat('%', #{driverName}, '%')</if>
            <if test="driverPhone != null  and driverPhone != ''"> and d.driver_phone = #{driverPhone}</if>
            <if test="driverType != null  and driverType != ''"> and d.driver_type = #{driverType}</if>
            <if test="fleetId != null"> and d.fleet_id = #{fleetId}</if>
            <if test="status != null  and status != ''"> and d.status = #{status}</if>
        </where>
        order by d.driver_id desc
    </select>

    <select id="selectLogisticsDriverByDriverId" parameterType="Long" resultMap="LogisticsDriverResult">
        <include refid="selectLogisticsDriverVo"/>
        where d.driver_id = #{driverId} and d.del_flag = '0'
    </select>

    <insert id="insertLogisticsDriver" parameterType="LogisticsDriver" useGeneratedKeys="true" keyProperty="driverId">
        insert into logistics_driver
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="driverName != null and driverName != ''">driver_name,</if>
            <if test="driverPhone != null and driverPhone != ''">driver_phone,</if>
            <if test="idCard != null">id_card,</if>
            <if test="driverLicense != null">driver_license,</if>
            <if test="driverType != null">driver_type,</if>
            <if test="fleetId != null">fleet_id,</if>
            <if test="vehiclePlate != null">vehicle_plate,</if>
            <if test="bankAccount != null">bank_account,</if>
            <if test="bankName != null">bank_name,</if>
            <if test="accountName != null">account_name,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="driverName != null and driverName != ''">#{driverName},</if>
            <if test="driverPhone != null and driverPhone != ''">#{driverPhone},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="driverLicense != null">#{driverLicense},</if>
            <if test="driverType != null">#{driverType},</if>
            <if test="fleetId != null">#{fleetId},</if>
            <if test="vehiclePlate != null">#{vehiclePlate},</if>
            <if test="bankAccount != null">#{bankAccount},</if>
            <if test="bankName != null">#{bankName},</if>
            <if test="accountName != null">#{accountName},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateLogisticsDriver" parameterType="LogisticsDriver">
        update logistics_driver
        <trim prefix="SET" suffixOverrides=",">
            <if test="driverName != null and driverName != ''">driver_name = #{driverName},</if>
            <if test="driverPhone != null and driverPhone != ''">driver_phone = #{driverPhone},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="driverLicense != null">driver_license = #{driverLicense},</if>
            <if test="driverType != null">driver_type = #{driverType},</if>
            <if test="fleetId != null">fleet_id = #{fleetId},</if>
            <if test="vehiclePlate != null">vehicle_plate = #{vehiclePlate},</if>
            <if test="bankAccount != null">bank_account = #{bankAccount},</if>
            <if test="bankName != null">bank_name = #{bankName},</if>
            <if test="accountName != null">account_name = #{accountName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where driver_id = #{driverId}
    </update>

    <delete id="deleteLogisticsDriverByDriverId" parameterType="Long">
        update logistics_driver set del_flag = '2' where driver_id = #{driverId}
    </delete>

    <delete id="deleteLogisticsDriverByDriverIds" parameterType="String">
        update logistics_driver set del_flag = '2' where driver_id in
        <foreach item="driverId" collection="array" open="(" separator="," close=")">
            #{driverId}
        </foreach>
    </delete>
</mapper>
