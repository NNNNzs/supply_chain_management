<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.logistics.mapper.LogisticsInvoiceDetailMapper">

    <resultMap type="LogisticsInvoiceDetail" id="LogisticsInvoiceDetailResult">
        <result property="detailId"    column="detail_id"    />
        <result property="batchId"    column="batch_id"    />
        <result property="orderId"    column="order_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="amount"    column="amount"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectLogisticsInvoiceDetailVo">
        select detail_id, batch_id, order_id, order_no, amount, remark from logistics_invoice_detail
    </sql>

    <select id="selectLogisticsInvoiceDetailList" parameterType="LogisticsInvoiceDetail" resultMap="LogisticsInvoiceDetailResult">
        <include refid="selectLogisticsInvoiceDetailVo"/>
        <where>
            <if test="batchId != null "> and batch_id = #{batchId}</if>
            <if test="orderId != null "> and order_id = #{orderId}</if>
            <if test="orderNo != null  and orderNo != ''"> and order_no like concat('%', #{orderNo}, '%')</if>
        </where>
        order by detail_id desc
    </select>

    <select id="selectLogisticsInvoiceDetailByDetailId" parameterType="Long" resultMap="LogisticsInvoiceDetailResult">
        <include refid="selectLogisticsInvoiceDetailVo"/>
        where detail_id = #{detailId}
    </select>

    <select id="selectDetailsByBatchId" parameterType="Long" resultMap="LogisticsInvoiceDetailResult">
        <include refid="selectLogisticsInvoiceDetailVo"/>
        where batch_id = #{batchId}
    </select>

    <select id="selectDetailByOrderId" parameterType="Long" resultMap="LogisticsInvoiceDetailResult">
        <include refid="selectLogisticsInvoiceDetailVo"/>
        where order_id = #{orderId}
        limit 1
    </select>

    <insert id="insertLogisticsInvoiceDetail" parameterType="LogisticsInvoiceDetail" useGeneratedKeys="true" keyProperty="detailId">
        insert into logistics_invoice_detail
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="batchId != null">batch_id,</if>
            <if test="orderId != null">order_id,</if>
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="amount != null">amount,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="batchId != null">#{batchId},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="amount != null">#{amount},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateLogisticsInvoiceDetail" parameterType="LogisticsInvoiceDetail">
        update logistics_invoice_detail
        <trim prefix="SET" suffixOverrides=",">
            <if test="batchId != null">batch_id = #{batchId},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where detail_id = #{detailId}
    </update>

    <delete id="deleteLogisticsInvoiceDetailByDetailId" parameterType="Long">
        delete from logistics_invoice_detail where detail_id = #{detailId}
    </delete>

    <delete id="deleteLogisticsInvoiceDetailByDetailIds" parameterType="String">
        delete from logistics_invoice_detail where detail_id in
        <foreach item="detailId" collection="array" open="(" separator="," close=")">
            #{detailId}
        </foreach>
    </delete>

    <delete id="deleteDetailsByBatchId" parameterType="Long">
        delete from logistics_invoice_detail where batch_id = #{batchId}
    </delete>
</mapper>
